# MongoDB connection string.
# Local dev default (install MongoDB Community Server, no account needed):
MONGO_URI=mongodb://localhost:27017
# Or use a hosted MongoDB Atlas cluster instead:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
DB_NAME=campuspulse

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to "true" to disable heavyweight AI models and use the lightweight
# extractive fallback (useful for local dev without a GPU / big downloads)
AI_LIGHTWEIGHT_MODE=true

# No email provider (SendGrid/SES/etc) is wired in yet, so password-reset
# and email-verification tokens are returned directly in the API response
# instead of being emailed, so the flow is testable end to end. Set to
# "false" once real email sending is wired up, so tokens are never
# exposed over the API.
DEV_MODE_EXPOSE_TOKENS=true
